{
  "name": "studioledger",
  "version": "0.1.0",
  "private": true,
  "description": "A creative studio wallet that bills, protects, and proves your work — all on XRPL.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset",
    "db:types": "supabase gen types typescript --local > src/types/database.ts",
    "test": "jest --verbose",
    "test:coverage": "jest --verbose --coverage",
    "seed:test-users": "node --env-file=.env.local scripts/seed-test-users.mjs",
    "seed:virtual-contracts": "node --env-file=.env.local scripts/seed-virtual-contracts.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.45.0",
    "@tanstack/react-query": "^5.50.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.6.0",
    "ed25519": "^0.0.5",
    "five-bells-condition": "^5.0.1",
    "lucide-react": "^0.400.0",
    "next": "^14.2.0",
    "pinata": "^2.5.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "ripple-binary-codec": "^2.1.0",
    "ripple-keypairs": "^2.0.0",
    "sharp": "^0.33.0",
    "tailwind-merge": "^2.4.0",
    "xrpl": "^4.6.0",
    "xumm-sdk": "^1.11.0",
    "zod": "^3.23.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "jest": "^30.3.0",
    "postcss": "^8.4.0",
    "supabase": "^1.180.0",
    "tailwindcss": "^3.4.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.5.0"
  }
}
