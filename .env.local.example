# ============================================
# WorkLedger Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git!

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH>
SUPABASE_SERVICE_ROLE_KEY=<sb_secret_N7UND0UgjKTVK-Uodkm0Hg_xSvEMPvz>

# --- XRPL ---
# Use testnet while developing, switch to mainnet for production
NEXT_PUBLIC_XRPL_NETWORK=testnet
NEXT_PUBLIC_XRPL_WSS=wss://s.altnet.rippletest.net:51233
# Mainnet: wss://xrplcluster.com

# Platform wallet (funds gas fees, receives platform fees)
XRPL_PLATFORM_ADDRESS=rYourPlatformAddress
XRPL_PLATFORM_SECRET=sYourPlatformSecret

# --- Xaman (Wallet Connect) ---
# Get your credentials at https://apps.xaman.dev/
# Dev mode: limited to 10 test users (whitelisted by device UUID)
# Production: requires XRPL Labs audit
XAMAN_API_KEY=your-xaman-api-key
XAMAN_API_SECRET=your-xaman-api-secret

# --- IPFS (Pinata) ---
PINATA_API_KEY=your-pinata-key
PINATA_SECRET_KEY=your-pinata-secret
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud

# --- Encryption Keys ---
# AES-256-GCM keys for encrypting secrets at rest. SEPARATE keys for defense in depth.
# Generate each with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CRITICAL: Back these up. If lost, encrypted data is unrecoverable.

# Encrypts escrow fulfillments (preimages) in milestones.fulfillment column
ESCROW_ENCRYPTION_KEY=your-64-char-hex-key-here

# Encrypts wallet seeds in users.wallet_seed_encrypted column (Philosophy A accounts)
WALLET_ENCRYPTION_KEY=your-64-char-hex-key-here

# --- App Config ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PLATFORM_FEE_PERCENT=0.98

# --- Dev / Testing ---
# Set to true to bypass Google OAuth in development (localhost only).
# The dev-session helper will impersonate the first creator in the DB.
# Use the /api/dev/switch-user endpoint or set a `dev-user-email` cookie to switch users.
# NEVER set this to true in production or staging.
NEXT_PUBLIC_SKIP_AUTH=true
