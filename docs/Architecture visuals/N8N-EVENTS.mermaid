  e2 --> slack
  e3 --> email
  e3 --> verify
  e4 --> email
  e4 --> slack
  e4 --> db
  e5 --> email
  e6 --> email
  e7 --> email
  e8 --> email
  e8 --> slack
  e8 --> verify
  e8 --> db
  e9 --> email
  e9 --> slack
  e10 --> panel
  e10 --> email
  e11 --> email
  e11 --> slack
  e12 --> payout
