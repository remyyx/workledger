---
title: StudioLedger — n8n Event Flow
---
flowchart LR
  subgraph Triggers["🎯 Trigger Sources"]
    auth["POST /api/auth"]
    contracts["POST /api/contracts"]
    milestones["POST /api/milestones/seq"]
    release["releaseMilestoneAndAdvance()"]
    mintFn["mintWorkCredentialOnRelease()"]
    adminAction["Admin Action"]
    schedule["Schedule (1h)"]
  end

  subgraph Events["⚡ 14 Event Types"]
    e1["user.registered"]
    e2["contract.created"]
    e3["contract.funded"]
    e4["contract.completed"]
    e5["milestone.funded"]
    e6["milestone.submitted"]
    e7["milestone.approved"]
    e8["milestone.released"]
    e9["milestone.disputed"]
    e10["dispute.opened"]
    e11["dispute.escalated"]
    e12["dispute.resolved"]
    e13["mcc.minted"]
    e14["escrow.expiring"]
  end

  subgraph Actions["📬 Downstream Actions"]
    email["📧 Email Notifications"]
    slack["💬 Slack Channels"]
    db["🗄️ Supabase Updates"]
    verify["🔍 XRPL Verification"]
    panel["⚖️ Panel Assignment"]
    payout["💰 Execute Payout"]
  end

  auth --> e1
  contracts --> e2
  milestones --> e3
  milestones --> e5
  milestones --> e6
  milestones --> e7
  milestones --> e9
  release --> e4
  release --> e8
  mintFn --> e13
  milestones --> e10
  adminAction --> e11
  adminAction --> e12
  schedule --> e14

  e1 --> email
