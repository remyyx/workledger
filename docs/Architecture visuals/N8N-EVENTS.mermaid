  e12 --> db
  e13 --> verify
  e13 --> email
  e13 --> db
  e14 --> email
  e14 --> slack

  classDef trigger fill:#1a2744,stroke:#3b82f6,color:#E6EDF3
  classDef event fill:#2d1f0a,stroke:#c9a84c,color:#E6EDF3
  classDef action fill:#0a2e1f,stroke:#10b981,color:#E6EDF3

  class auth,contracts,milestones,release,mintFn,adminAction,schedule trigger
